models/
onnx_artifacts/
outputs/
logs/
dataset/
*.pt
*.bin
*.onnx
*.json

# ── Virtual environment ───────────────────────────────────────────────────────
sm/

# ── Hugging Face cache ────────────────────────────────────────────────────────
.hf_cache/

# ── Internal / scratch ────────────────────────────────────────────────────────
LayoutLM/graph_linking/
eval.json
eval.md
funsd-analyse-dataset (1).ipynb
ocr_eval_report_*.json
LayoutLM/onnx_artifacts/
LayoutLM/domain_generalization_artifacts/

# Whitelist: Allow benchmark reports and technical evidence
!LayoutLM/eval_results/*.json
!LayoutLM/*_artifacts/*.json
!LayoutLM/*_artifacts/*.md

DESIGN_DECISIONS.md
EVALUATION_STATUS.md
REPRODUCIBILITY_GUIDE.md
RESULTS_INTERPRETATION.md
Project3_Grading_Report_COMPLETE.md

# ── Model checkpoints (excluded from repo) ───────────────────────────────────
# Ignore ALL checkpoint subfolders globally first.
**/checkpoint-*/

# Unignore ONLY the specific production-ready checkpoints used for inference.
# 1. Main GT-baseline model (Editor Default)
!LayoutLM/layoutlmv3-funsd/checkpoint-608/
!LayoutLM/layoutlmv3-funsd/checkpoint-608/**

# NOTE: If you wish to maintain the 79% F1 results from the optimized pipeline, 
# you would also need checkpoint-1250. Currently ignored to keep repo small.

# Exclude entire experiment/archive directories.
LayoutLM/layoutlmv3-funsd-paddle/
LayoutLM/layoutlmv3-funsd-tesseract/
LayoutLM/layoutlmv3-funsd-zero-bbox/
LayoutLM/docformer-*/
UDOP/udop-funsd/
LayoutLM/layout_graph_artifacts/
LayoutLM/onnx_artifacts_gt
LayoutLM/layoutlmv3-funsd-doctr/
LayoutLM/layoutlmv3-funsd-doctr-base/
LayoutLM/layoutlmv3-funsd-doctr-base-res224/
LayoutLM/layoutlmv3-funsd-doctr-large/

# ── Mobile / Deployment ───────────────────────────────────────────────────────
*.mlpackage/
*.mlmodel
*.onnx
LayoutLM/iOSTestApp/DerivedData/
LayoutLM/iOSTestApp/*.xcodeproj/project.xcworkspace/
LayoutLM/iOSTestApp/*.xcodeproj/xcuserdata/

# ── Training-only artifacts (not needed for inference) ────────────────────────
# Must come AFTER the negation rules above so they re-apply to un-ignored dirs.
**/optimizer.pt
**/rng_state.pth
**/scheduler.pt
**/trainer_state.json
**/training_args.bin

AUDIT_REPORT.md